{
  "name": "vue-quill-ssr-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server.mjs",
    "dev:npm": "node server.mjs --mode npm",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:npm": "npm run build:client -- --mode npm && npm run build:server -- --mode npm",
    "preview": "NODE_ENV=production node server.mjs",
    "test:ssr": "npm run typecheck && npm run build && node scripts/smoke-ssr.mjs"
  },
  "dependencies": {
    "@vue/server-renderer": "^3.5.35",
    "@vueup/vue-quill": "^1.3.0",
    "express": "^5.2.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "~6.0.3",
    "vite": "^8.0.15",
    "vue-tsc": "^3.3.3"
  }
}
