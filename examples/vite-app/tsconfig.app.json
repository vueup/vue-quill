{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],
    "paths": {
      "@vue-quill-example/*": ["../vue-quill/src/*"],
      "@vueup/vue-quill": [
        "./node_modules/@vueup/vue-quill/dist/vue-quill.d.ts"
      ]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "../vue-quill/src/**/*.ts",
    "../vue-quill/src/**/*.vue"
  ],
  "exclude": ["../vue-quill/src/**/*.test.ts"]
}
