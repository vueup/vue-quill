{
  "private": true,
  "name": "vue-quill-monorepo",
  "version": "0.0.0",
  "type": "module",
  "description": "Vue 3.5+ Rich Text Editor powered by Quill 2.x",
  "homepage": "https://vueup.github.io/vue-quill/",
  "bugs": "https://github.com/vueup/vue-quill/issues",
  "license": "MIT",
  "author": "Ahmad Luthfi Masruri",
  "funding": [
    {
      "type": "individual",
      "url": "https://www.buymeacoffee.com/luthfimasruri"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vueup/vue-quill.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "dev": "pnpm --filter @vueup/vue-quill dev",
    "build": "pnpm --filter @vueup/vue-quill build",
    "test": "pnpm --filter @vueup/vue-quill test",
    "test:coverage": "pnpm --filter @vueup/vue-quill test:coverage",
    "type-check": "pnpm --filter @vueup/vue-quill type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo:dev": "pnpm --filter demo dev",
    "demo:build": "pnpm --filter demo build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "prepare": "echo 'Ready for development'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "turbo": "^2.6.1",
    "typescript": "^5.7.2"
  }
}
