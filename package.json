{
  "private": true,
  "name": "vueup",
  "version": "0.0.0",
  "type": "module",
  "description": "Vue 3.5+ Rich Text Editor powered by Quill 2.x",
  "homepage": "https://vueup.github.io/vue-quill/",
  "bugs": "https://github.com/vueup/vue-quill/issues",
  "license": "MIT",
  "author": "Ahmad Luthfi Masruri",
  "funding": [
    {
      "type": "individual",
      "url": "https://www.buymeacoffee.com/luthfimasruri"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vueup/vue-quill.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "dev": "turbo dev --filter=@vueup/vue-quill",
    "build": "turbo build --filter=@vueup/vue-quill",
    "test": "turbo test --filter=@vueup/vue-quill",
    "test:coverage": "turbo test:coverage --filter=@vueup/vue-quill",
    "type-check": "turbo type-check --filter=@vueup/vue-quill",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo:dev": "turbo dev --filter=demo",
    "demo:build": "turbo build --filter=demo",
    "docs:dev": "turbo dev --filter=docs",
    "docs:build": "turbo build --filter=docs",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf .turbo",
    "prepare": "echo 'Ready for development'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "prettier": "^3.4.2",
    "turbo": "^2.6.1",
    "typescript": "^5.7.2"
  }
}