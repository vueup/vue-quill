{
  "name": "@vueup/vue-quill",
  "version": "2.0.0-alpha.0",
  "type": "module",
  "description": "Vue 3.5+ Rich Text Editor powered by Quill 2.x",
  "author": "Ahmad Luthfi Masruri",
  "license": "MIT",
  "homepage": "https://vueup.github.io/vue-quill/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vueup/vue-quill.git"
  },
  "bugs": {
    "url": "https://github.com/vueup/vue-quill/issues"
  },
  "keywords": [
    "vue",
    "vue3",
    "vue-quill",
    "quill",
    "quill2",
    "rich-text-editor",
    "wysiwyg",
    "text-editor",
    "editor",
    "vue-component"
  ],
  "sideEffects": [
    "*.css",
    "*.vue"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue-quill.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue-quill.cjs.js"
      }
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/vue-quill.cjs.js",
  "module": "./dist/vue-quill.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "quill": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
